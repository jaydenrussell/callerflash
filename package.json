{
  "name": "callerflash",
  "private": true,
  "version": "1.4.2",
  "main": "electron/main.cjs",
  "author": "CallerFlash",
  "description": "SIP-compliant client with toast notifications for any standard SIP provider",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:build": "npm run build && npx electron-builder --win --x64 --publish never",
    "electron:publish": "npm run build && npx electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "sip": "^0.0.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "clsx": "2.1.1",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-log": "^5.0.1",
    "electron-updater": "^6.3.9",
    "ico-endec": "^0.1.6",
    "lucide-react": "^1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "typescript": "^6.0.3",
    "vite": "8.1.0",
    "vite-plugin-singlefile": "2.3.3",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.callerflash.app",
    "productName": "CallerFlash",
    "directories": {
      "output": "release",
      "buildResources": "buildResources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "buildResources/**"
    ],
    "artifactName": "CallerFlash-${version}.${ext}",
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CallerFlash",
      "installerIcon": "cflogo.ico",
      "uninstallerIcon": "cflogo.ico",
      "installerHeaderIcon": "cflogo.ico",
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "jaydenrussell",
      "repo": "CallerFlash"
    },
    "extraResources": [
      {
        "from": "buildResources/cflogo.ico",
        "to": "cflogo.ico"
      },
      {
        "from": "buildResources/cflogo.png",
        "to": "cflogo.png"
      },
      {
        "from": "buildResources/app.ico",
        "to": "app.ico"
      }
    ]
  }
}
